# 继续追问 — 环境变量配置清单
# 复制此文件为 .env 并填入实际值
# Railway 部署时在 Variables 中配置，不需要 .env 文件

# ---- 必填 ----

# TikHub API 密钥（获取抖音数据）
TIKHUB_API_KEY=

# Anthropic Claude API 密钥（AI 分析）
ANTHROPIC_API_KEY=

# PostgreSQL 数据库连接地址
DATABASE_URL=

# 网站访问密码
SITE_PASSWORD=

# ---- 选填（飞书集成，不用可留空）----

# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书多维表格
FEISHU_BITABLE_APP_TOKEN=
FEISHU_TABLE_ACCOUNTS=
FEISHU_TABLE_VIDEOS=
FEISHU_TABLE_SNAPSHOTS=
FEISHU_TABLE_COMMENTS=
FEISHU_TABLE_ANALYSES=
